# ─── Application ──────────────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO

# ─── Model ────────────────────────────────────────────────────────────────────
MODEL_SAVE_PATH=model/saved/best_model.pt
PREDICTION_HORIZON_STEPS=12   # 12 × 5 min = 60 min

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite used for logging predictions (no server needed)
SQLITE_DB_PATH=data/predictions.db

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
